
{
    "authenticationMethod": "route",
    "routes": [
        {
            "source": "^/fastapi/(.*)$",
            "destination": "fastapi-app",
            "csrfProtection": true
        }
    ]
}

/*
Documentation:
- authenticationMethod: Defines the method of authentication for the application, set to 'route'.
- routes: Specifies the routing configurations, including source pattern and destination.
- csrfProtection: Enables CSRF protection for enhanced security. 
*/
